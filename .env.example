# Spotify API Credentials
# Get your credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Last.fm API Key
# Get your API key at: https://www.last.fm/api/account/create
LAST_FM_KEY=your_lastfm_api_key_here

# PostgreSQL Database Configuration
DB_NAME=music_db
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# Kafka Configuration (legacy)
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Snowflake (active ELT path)
# JWT key-pair auth: path to your private key PEM (see snowflake_utils / profiles.yml)
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=MUSICDB
SNOWFLAKE_SCHEMA=RAW
